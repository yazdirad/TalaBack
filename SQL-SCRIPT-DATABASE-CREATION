-- View برای دیدن کاملِ دسترسی‌های هر کاربر
CREATE VIEW vw_UserPermissions AS
SELECT 
    u.user_id,
    u.email,
    u.first_name,
    u.last_name,
    t.tenant_id,
    t.tenant_name,
    r.role_id,
    r.role_name,
    rl.role_level_id,
    rl.level_number,
    rl.level_name,
    p.permission_id,
    p.permission_name,
    p.category
FROM Users u
INNER JOIN UserTenantRoles utr ON u.user_id = utr.user_id
INNER JOIN Tenants t ON utr.tenant_id = t.tenant_id
INNER JOIN Roles r ON utr.role_id = r.role_id
INNER JOIN RoleLevels rl ON utr.role_level_id = rl.role_level_id
LEFT JOIN RoleLevelPermissions rlp ON rl.role_level_id = rlp.role_level_id
LEFT JOIN Permissions p ON rlp.permission_id = p.permission_id
WHERE u.status = 'active' AND utr.status = 'active';
GO

-- View برای دیدن موجودی کاربر در هر Tenant
CREATE VIEW vw_UserWalletSummary AS
SELECT 
    u.user_id,
    u.email,
    u.first_name,
    u.last_name,
    t.tenant_id,
    t.tenant_name,
    w.wallet_id,
    w.wallet_balance,
    m.metal_name,
    p.purity,
    wm.quantity,
    wm.reserved_quantity,
    (wm.quantity - wm.reserved_quantity) AS available_quantity
FROM Users u
INNER JOIN Wallets w ON u.user_id = w.user_id
INNER JOIN Tenants t ON w.tenant_id = t.tenant_id
LEFT JOIN WalletMetals wm ON w.wallet_id = wm.wallet_id
LEFT JOIN Products prod ON wm.product_id = prod.product_id
LEFT JOIN Metals m ON prod.metal_id = m.metal_id;
GO

