-- 9. STORED PROCEDURES برای عملیات پرکاربرد
-- ============================================================

-- SP برای ایجاد تراکنش منتقل کیف پول
CREATE PROCEDURE sp_TransferWalletMetals
    @fromUserId UNIQUEIDENTIFIER,
    @toUserId UNIQUEIDENTIFIER,
    @tenantId UNIQUEIDENTIFIER,
    @productId UNIQUEIDENTIFIER,
    @quantity DECIMAL(18, 6),
    @description NVARCHAR(MAX),
    @createdByUserId UNIQUEIDENTIFIER,
    @transactionId UNIQUEIDENTIFIER OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;
        
        -- متغیرهای محلی
        DECLARE @fromWalletId UNIQUEIDENTIFIER;
        DECLARE @toWalletId UNIQUEIDENTIFIER;
        DECLARE @unitPrice DECIMAL(18, 2) = 0;
        DECLARE @totalAmount DECIMAL(18, 2);
        
        -- پیدا کردن کیف پول‌ها
        SELECT @fromWalletId = wallet_id FROM Wallets 
        WHERE user_id = @fromUserId AND tenant_id = @tenantId;
        
        SELECT @toWalletId = wallet_id FROM Wallets 
        WHERE user_id = @toUserId AND tenant_id = @tenantId;
        
        IF @fromWalletId IS NULL OR @toWalletId IS NULL
        BEGIN
            RAISERROR('Wallet not found', 16, 1);
        END;
        
        -- بررسی موجودی کافی
        DECLARE @availableQuantity DECIMAL(18, 6);
        SELECT @availableQuantity = (quantity - ISNULL(reserved_quantity, 0))
        FROM WalletMetals 
        WHERE wallet_id = @fromWalletId AND product_id = @productId;
        
        IF @availableQuantity < @quantity
        BEGIN
            RAISERROR('Insufficient quantity in wallet', 16, 1);
        END;
        
        -- محاسبه مبلغ کل
        SET @totalAmount = @quantity * @unitPrice;
        
        -- ایجاد تراکنش
        SET @transactionId = NEWID();
        INSERT INTO Transactions (
            transaction_id, tenant_id, transaction_type, from_user_id, to_user_id,
            product_id, quantity, unit_price, total_amount, payment_method,
            status, description, created_by_user_id, created_at
        ) VALUES (
            @transactionId, @tenantId, 'TRANSFER', @fromUserId, @toUserId,
            @productId, @quantity, @unitPrice, @totalAmount, 'WALLET_TRANSFER',
            'completed', @description, @createdByUserId, GETDATE()
        );
        
        -- کاهش موجودی فروشنده
        UPDATE WalletMetals 
        SET quantity = quantity - @quantity, updated_at = GETDATE()
        WHERE wallet_id = @fromWalletId AND product_id = @productId;
        
        -- افزایش موجودی خریدار
        UPDATE WalletMetals 
        SET quantity = quantity + @quantity, updated_at = GETDATE()
        WHERE wallet_id = @toWalletId AND product_id = @productId;
        
        -- ثبت در Audit Log
        INSERT INTO AuditLog (
            audit_id, tenant_id, user_id, action, entity_type, entity_id,
            old_value, new_value, status, created_at
        ) VALUES (
            NEWID(), @tenantId, @createdByUserId, 'TRANSFER', 'WALLET_METALS',
            CAST(@productId AS NVARCHAR(MAX)),
            N'From: ' + CAST(@fromUserId AS NVARCHAR(MAX)),
            N'To: ' + CAST(@toUserId AS NVARCHAR(MAX)),
            'SUCCESS', GETDATE()
        );
        
        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;
        
        INSERT INTO AuditLog (
            audit_id, tenant_id, user_id, action, entity_type, entity_id,
            error_message, status, created_at
        ) VALUES (
            NEWID(), @tenantId, @createdByUserId, 'TRANSFER', 'WALLET_METALS',
            CAST(@productId AS NVARCHAR(MAX)),
            ERROR_MESSAGE(),
            'FAILED', GETDATE()
        );
        
        THROW;
    END CATCH;
END;
GO

